{
  "name": "hermes-repo",
  "private": true,
  "description": "跨编程助手的项目级记忆系统（monorepo）",
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "packages/*"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ricoNext/hermes-repo.git"
  },
  "scripts": {
    "build": "bun run --filter '@riconext/hermes-repo' build && bun run --filter '@riconext/hermes-mcp-server' build && bun run --filter '@riconext/hermes-ui' build",
    "dev": "bun run --filter '@riconext/hermes-repo' dev",
    "dev:ui": "bun run --filter '@riconext/hermes-ui' dev",
    "dev:mcp": "bun run --filter '@riconext/hermes-mcp-server' dev",
    "test": "bun run --filter '@riconext/hermes-repo' test",
    "typecheck": "bun run --filter '*' typecheck",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "node scripts/release.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  },
  "engines": {
    "node": ">=20"
  }
}
